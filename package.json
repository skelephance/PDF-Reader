{
  "name": "libra-local",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Libra-Local — premium, local-first, offline PDF reader.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "tsc --noEmit && vite build --config vite.web.config.ts && cp dist-web/web.html dist-web/index.html",
    "preview:web": "vite preview --config vite.web.config.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "pdfjs-dist": "^4.7.76"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
